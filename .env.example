# =============================================================================
# halpmeAIML Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Database ---
# On Mac with Homebrew PostgreSQL, use your macOS username with no password:
#   DATABASE_URL=postgresql://yourname@localhost:5432/halpmeaiml
DATABASE_URL=postgresql://joanlee@localhost:5432/halpmeaiml

# --- LLM Provider (options: ollama, groq, openai) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Embedding Provider (options: local, openai) ---
EMBEDDING_PROVIDER=local
EMBEDDING_SERVER_URL=http://localhost:5001

# --- Vector Store (options: chroma, pgvector) ---
VECTOR_STORE=chroma
CHROMA_URL=http://localhost:8000

# --- Google OAuth (Calendar + YouTube scopes) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- ElevenLabs TTS (free tier: 10,000 chars/month) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Stripe (Phase 2) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Encryption ---
ENCRYPTION_KEY=generate-a-32-byte-hex-key-here

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
